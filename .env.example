# ─────────────────────────────────────────────
# bmp-ai-dmp 환경변수 예시
# 실제 값은 PO 문의 / Supabase de_admin_credentials 동적 조회
# ⚠️ 실제 값이 담긴 .env.local 은 절대 커밋 금지
# ─────────────────────────────────────────────

# Supabase (클라이언트 노출 — RLS 필수 전제)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# data-worker (🔒 서버 전용 — NEXT_PUBLIC_ 접두사 절대 금지)
DATA_WORKER_URL=https://data-worker-production-84d4.up.railway.app
DMP_MCP_API_KEY=<worker-api-key>

# 인증 (🔒 서버 전용)
JWT_SECRET=<jwt-signing-secret>
